# ──────────────────────────────────────────────────────────────────────────────
# Database (required)
# ──────────────────────────────────────────────────────────────────────────────

# MongoDB Atlas connection string. Required.
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority

# MongoDB database name. Optional — defaults to "zicha-study".
MONGODB_DB=zicha-study

# ──────────────────────────────────────────────────────────────────────────────
# Authentication (NextAuth.js v5 + Microsoft Entra ID, personal accounts)
# ──────────────────────────────────────────────────────────────────────────────

# Secret used by Auth.js to sign/encrypt JWTs and CSRF tokens. Required.
# Generate with:  openssl rand -base64 32
AUTH_SECRET=

# Microsoft Entra ID app registration credentials. Required.
# The app must be registered for "Personal Microsoft accounts only" and have
# the following Graph permissions: User.Read, Files.Read.All, Files.ReadWrite.All
# plus offline_access for refresh tokens.
AUTH_MICROSOFT_ENTRA_ID_ID=
AUTH_MICROSOFT_ENTRA_ID_SECRET=

# Comma-separated list of email addresses allowed to sign in.
# Optional — leave empty to allow any successfully authenticated account.
ALLOWED_EMAILS=

# ──────────────────────────────────────────────────────────────────────────────
# Public share URLs (optional)
# See README.md and docs/VERCEL_DEPLOYMENT.md for details.
# These are NEXT_PUBLIC_* and inlined at build time.
# ──────────────────────────────────────────────────────────────────────────────

# When "true", share-link previews render the study slug as a subdomain
# (e.g. https://newton.zicha.study/mat). Leave unset locally so previews
# stay on http://localhost:3001/<slug>.
NEXT_PUBLIC_USE_SUBDOMAIN_SHARE_URLS=

# Apex domain used when subdomain mode is enabled, e.g. "zicha.study".
NEXT_PUBLIC_SHARE_BASE_DOMAIN=

# ──────────────────────────────────────────────────────────────────────────────
# Build metadata (optional)
# next.config.mjs auto-detects these from git / common CI providers.
# Only set them to override the auto-detected values.
# ──────────────────────────────────────────────────────────────────────────────

# Commit SHA shown in the footer. Falls back to GITHUB_SHA,
# VERCEL_GIT_COMMIT_SHA, COMMIT_SHA, CF_PAGES_COMMIT_SHA, RENDER_GIT_COMMIT,
# then `git rev-parse HEAD`, then "development".
NEXT_PUBLIC_COMMIT_SHA=

# Build timestamp (ISO 8601). Falls back to BUILD_TIME, then `new Date()`
# at build time.
NEXT_PUBLIC_BUILD_TIME=
